; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited with care.

[application]

config/name="Little Car Borrow"
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")

[autoload]

EventBus="*res://src/autoloads/event_bus.gd"
GameManager="*res://src/autoloads/game_manager.gd"
InputManager="*res://src/autoloads/input_manager.gd"
WantedLevelManager="*res://src/autoloads/wanted_level_manager.gd"
AudioManager="*res://src/autoloads/audio_manager.gd"
DayNightManager="*res://src/autoloads/day_night_manager.gd"
MissionManager="*res://src/autoloads/mission_manager.gd"
SettingsManager="*res://src/autoloads/settings_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/resizable=true
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

