[layer_names]

3d_physics/layer_1="Ground"
3d_physics/layer_2="Static"
3d_physics/layer_3="PlayerFoot"
3d_physics/layer_4="PlayerVehicle"
3d_physics/layer_5="NPCVehicle"
3d_physics/layer_6="Pedestrian"
3d_physics/layer_7="Police"
3d_physics/layer_8="Projectile"
3d_physics/layer_9="Trigger"
3d_physics/layer_10="Navigation"

[physics]

common/physics_ticks_per_second=120

[rendering]

renderer/rendering_method="forward_plus"
renderer/rendering_method.web="gl_compatibility"
anti_aliasing/quality/msaa_3d=1
